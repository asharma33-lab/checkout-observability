{
  "name": "@vitafleet/checkout-observability",
  "version": "0.1.0",
  "description": "OpenTelemetry tracing, circuit breaker, and monitoring for VitaFleet checkout-service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
