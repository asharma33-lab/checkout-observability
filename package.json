    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@opentelemetry/api": "^1.9.0",
    "opossum": "^8.4.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0",
